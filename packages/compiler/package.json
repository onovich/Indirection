{
  "name": "@indirection/compiler",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/onovich/Indirection.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/onovich/Indirection#readme",
  "keywords": [
    "indirection",
    "assets",
    "asset-id",
    "game-tools",
    "compiler",
    "catalog"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@indirection/protocol": "workspace:*",
    "@indirection/schema": "workspace:*"
  }
}
