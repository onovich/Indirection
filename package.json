{
  "name": "indirection",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "pnpm build && vitest run",
    "test:browser": "node scripts/browser-smoke.mjs",
    "test:e2e": "pnpm build && playwright test",
    "pack:check": "node scripts/pack-check.mjs",
    "check:docs": "node scripts/docs-drift-check.mjs",
    "check:boundaries": "node scripts/core-boundary-check.mjs",
    "smoke:cli": "pnpm build && node scripts/cli-smoke.mjs",
    "smoke:phase7": "pnpm build && node examples/phase7-advanced-loaders.mjs",
    "validate:full": "pnpm lint && pnpm format && pnpm check:docs && pnpm typecheck && pnpm test && pnpm test:browser && pnpm check:boundaries && pnpm smoke:cli && pnpm smoke:phase7 && pnpm pack:check",
    "test:watch": "vitest",
    "lint": "node scripts/lint-check.mjs",
    "format": "node scripts/format-check.mjs"
  },
  "devDependencies": {
    "@indirection/cli": "workspace:*",
    "@indirection/compiler": "workspace:*",
    "@indirection/loaders-web": "workspace:*",
    "@indirection/protocol": "workspace:*",
    "@indirection/runtime": "workspace:*",
    "@indirection/schema": "workspace:*",
    "@indirection/testkit": "workspace:*",
    "@indirection/three": "workspace:*",
    "@indirection/vite": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@types/node": "24.13.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
